# Hygiene for the wp7-course-public subdataset.
#
# This file is intentionally minimal: the public/ subdataset only holds the
# mkdocs site (site/) and student-distributable course materials
# (course-materials/). No build outputs, no test scratch, no real Python
# project.  The TA tools and student env live one level up in the outer
# wp7-course tree, where their own .gitignore handles them.

# Python bytecode caches (e.g. course-materials/lib/__pycache__/ from
# importing wp7_helpers.py during a smoke test or dev session).
__pycache__/
*.py[cod]

# Jupyter checkpoint scratch — only relevant if anyone opens a notebook
# from public/ in jupyter; the projio outer .gitignore also excludes this
# at the super level.
.ipynb_checkpoints/

# pixi local env cache, in case anyone ever runs `pixi install` from
# inside the subdataset (canonical install lives at /storage2/wp7/env/).
.pixi/

# mkdocs Pages build output.  GitLab CI builds into ./public/ here on
# every push to master; that path collides with the outer's `public/`
# subdataset name but is unambiguous inside the CI runner.  We never
# commit the build output — Pages reads it as a job artifact.
/public/
/site_build/
